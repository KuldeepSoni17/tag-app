PORT=4000
DATABASE_URL="postgresql://tagapp:tagapp@localhost:5433/tagapp?schema=public"
REDIS_URL="redis://localhost:6380"
JWT_SECRET=change-me-long-random
JWT_EXPIRES_IN=30d
PHONE_PEPPER=change-me-phone-pepper
# 32-byte hex for AES-256-GCM (generate: openssl rand -hex 32)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ADMIN_SECRET=dev-admin-secret-change-me
# Local dev without MSG91: set and omit MSG91_* ; never use in production
# DEV_STATIC_OTP=123456

# MSG91 (https://msg91.com/help/api/)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=

# Admin HTTP API (Bearer token)
ADMIN_SECRET=

# Razorpay payouts (optional for local dev)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_ACCOUNT_NUMBER=

# FCM server key / service account JSON path — wired in notificationService when set
FCM_SERVER_KEY=
